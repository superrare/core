# Bazaar empty staking registry update
# Copy this file to .env and update values for your target network.

# Network configuration
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR-API-KEY
CHAIN_ID=84532

# Deployment account
PRIVATE_KEY=your_private_key_here

# Bazaar contract to update
BAZAAR_ADDRESS=0x0000000000000000000000000000000000000000

# Optional verification
ETHERSCAN_API_KEY=your_etherscan_api_key
