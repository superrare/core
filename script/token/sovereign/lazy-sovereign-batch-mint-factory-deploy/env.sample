# LazySovereignBatchMintFactory Deployment Environment Variables
# Copy this file to .env and update the values for your target environment

# Network Configuration
# ----
# RPC URL for the target network
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY  # For Sepolia testnet
# RPC_URL=http://localhost:8545  # For local development

# Deployment Account
# ----
# Private key for the deploying account (with 0x prefix)
# This account must have sufficient ETH to cover gas costs
PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234

# Factory Configuration (Optional)
# ----
# Address that will own the LazySovereignBatchMintFactory contract
# If not provided, defaults to the deployer address
# FACTORY_OWNER=0x1234567890123456789012345678901234567890

# Implementation Contract (Optional)
# ----
# Address of an existing LazySovereignBatchMint implementation contract
# If not provided, a new implementation will be deployed
# LAZY_SOVEREIGN_BATCH_MINT_IMPLEMENTATION=0x1234567890123456789012345678901234567890

# Prepare Mint Configuration (for prepare-mint.sh)
# ----
# Address of the deployed LazySovereignBatchMintFactory contract
# FACTORY_ADDRESS=0x0577eFF5683F5195eDE2f656C7112bAdFcf83350
# Name for the new NFT collection
# NFT_NAME=My Lazy NFT Collection
# Symbol for the new NFT collection
# NFT_SYMBOL=LAZY
# Maximum number of tokens allowed (default: 10000)
# MAX_TOKENS=10000
# Base URI for token metadata (e.g., "https://api.example.com/metadata/")
# BASE_URI=https://api.example.com/metadata/
# Number of tokens to prepare for minting
# NUMBER_OF_TOKENS=100

# Contract Verification
# ----
# Etherscan API key for contract verification (optional but recommended)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Chain ID for the target network
CHAIN_ID=1          # 1 for Ethereum Mainnet
# CHAIN_ID=11155111 # 11155111 for Sepolia testnet
# CHAIN_ID=31337    # 31337 for local development (Hardhat/Anvil)

# Verification URL (auto-detected based on chain but can be overridden)
# VERIFIER_URL=https://api.etherscan.io/api  # Ethereum Mainnet
# VERIFIER_URL=https://api-sepolia.etherscan.io/api  # Sepolia testnet

# Network-specific Chain IDs:
# - Ethereum Mainnet: 1
# - Sepolia Testnet: 11155111
# - Polygon: 137
# - Polygon Mumbai: 80001
# - Arbitrum One: 42161
# - Optimism: 10
